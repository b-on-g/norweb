$raggu_web_front_export $mol_pop
	screen \gallery
	showed? false
	align \bottom_right
	export_btn_text @ \↓ Export
	empty_text @ \Nothing to export
	Anchor $bog_builderui_div
		event * click? <=> toggle? null
		sub / <= export_btn_text
	bubble_content /
		<= Menu $bog_builderui_menu
			items <= items /
	Item* $bog_builderui_menu_item
		title <= item_label* \
		click? <=> item_click*? null
	Empty $bog_builderui_div
		sub / <= empty_text
