$raggu_web_front_sidebar_nav $bog_builderui_div
	icon \
	label \
	active false
	disabled false
	click? null
	attr *
		^
		raggu_web_front_sidebar_nav_active <= active
		raggu_web_front_sidebar_nav_disabled <= disabled
	event *
		^
		click? <=> click? null
	sub /
		<= Icon $bog_builderui_div sub / <= icon
		<= Label $bog_builderui_div sub / <= label
