$bog_norweb_front_chat $bog_builderui_div
	dataset_id \
	sug_one_text @ \Who received the Nobel Prize?
	sug_two_text @ \Connection between Ibsen and Bjørnson?
	input_hint_text @ \Ask anything about the corpus…
	send_label_text @ \Send
	seed_user_text @ \Who wrote the Norwegian anthem and when?
	seed_assistant_text @ \The Norwegian anthem was written by Bjørnstjerne Bjørnson in 1859…
	clear_text @ \Clear
	off_graph_text @ \⚠ Off-graph answer (LLM without retrieval)
	prompt_text? \
	prompt_submit? null
	use_sug_one? null
	use_sug_two? null
	clear_click? null
	rows /
	message_text* \
	message_role* \
	message_off_graph* false
	sub /
		<= Body $mol_scroll
			sub /
				<= Body_flow $bog_builderui_div sub /
					<= Messages $mol_list rows <= rows
					<= Status $bog_builderui_card
						attr *
							^
							raggu_loading <= is_communicating false
						sub /
							<= Skel_line_one $bog_builderui_skeleton
							<= Skel_line_two $bog_builderui_skeleton
							<= Skel_line_three $bog_builderui_skeleton
		<= Footer $bog_builderui_div sub /
			<= Suggestions $bog_builderui_div sub /
				<= Sug_one $bog_builderui_div
					sub / <= sug_one_text
					event * click? <=> use_sug_one? null
				<= Sug_two $bog_builderui_div
					sub / <= sug_two_text
					event * click? <=> use_sug_two? null
				<= Clear $mol_button_minor
					hint <= clear_text
					click? <=> clear_click? null
					sub / \✕
			<= Input_row $bog_builderui_div sub /
				<= Prompt $mol_textarea
					hint <= input_hint_text
					value? <=> prompt_text? \
					submit? <=> prompt_submit? null
				<= Input_send $mol_button_minor
					hint <= send_label_text
					click? <=> prompt_submit? null
					sub / \↑
	Message* $bog_builderui_div
		attr *
			^
			raggu_role <= message_role*
		sub /
			<= Message_text* $bog_builderui_div
				attr *
					^
					raggu_role <= message_role*
				sub / <= message_text*
			<= Message_badge* $bog_builderui_div
				attr *
					^
					raggu_off_graph <= message_off_graph*
				sub / <= off_graph_text
