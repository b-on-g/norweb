$bog_norweb_front_settings_group $bog_builderui_div
	step \
	title \
	opts \
	controls /
	reindex true
	reindex_text @ \requires reindexing
	sub /
		<= Head $bog_builderui_div sub /
			<= Step $bog_builderui_div sub / <= step
			<= Reindex $bog_builderui_div
				attr * bog_norweb_front_settings_group_reindex <= reindex
				sub / <= reindex_text
		<= Title $bog_builderui_div sub / <= title
		<= Opts $bog_builderui_div sub / <= opts
		<= Controls $bog_builderui_div sub <= controls
