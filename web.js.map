$bog_norweb_front_dashboard $bog_builderui_div
	metrics /
	stages /
	logs /
	title_text @ \Corpus dashboard
	subtitle_text @ \Graph stats · quality · energy and cost · timings and logs
	card_stats_label_text @ \① Graph stats
	stat_nodes_lbl_text @ \nodes
	stat_edges_lbl_text @ \edges
	stat_comms_lbl_text @ \communities
	stats_dist_text @ \entity type distribution
	card_quality_label_text @ \② Quality (benchmarks)
	quality_footer_text @ \RAGU vs LightRAG / HippoRAG2 / Naive
	card_energy_label_text @ \③ Energy and cost
	energy_kwh_lbl_text @ \kWh / corpus
	energy_cost_lbl_text @ \$ vs GPT-4 API
	energy_formula_text @ \kWh = TDP × time × PUE
	energy_note_text @ \TDP 300W · PUE 1.4 · meno-lite 7B locally vs ~40k tokens/doc on gpt-4o pricing
	card_timings_label_text @ \④ Pipeline timings
	card_logs_label_text @ \Query logs (expand into trace)
	trace_label_text @ \ENTITIES IN CONTEXT
	trace_link_text @ \↳ highlight on graph
	sub /
		<= Title $bog_builderui_div sub / <= title_text
		<= Subtitle $bog_builderui_div sub / <= subtitle_text
		<= Grid $bog_builderui_div sub /
			<= Card_stats $bog_builderui_div sub /
				<= Card_stats_label $bog_builderui_div sub / <= card_stats_label_text
				<= Stats_row $bog_builderui_div sub /
					<= Stat_nodes $bog_builderui_div sub /
						<= Stat_nodes_val $bog_builderui_div sub / \2 410
						<= Stat_nodes_lbl $bog_builderui_div sub / <= stat_nodes_lbl_text
					<= Stat_edges $bog_builderui_div sub /
						<= Stat_edges_val $bog_builderui_div sub / \7 088
						<= Stat_edges_lbl $bog_builderui_div sub / <= stat_edges_lbl_text
					<= Stat_comms $bog_builderui_div sub /
						<= Stat_comms_val $bog_builderui_div sub / \38
						<= Stat_comms_lbl $bog_builderui_div sub / <= stat_comms_lbl_text
				<= Stats_dist $bog_norweb_front_dashboard_dist sub / <= stats_dist_text
			<= Card_quality $bog_builderui_div sub /
				<= Card_quality_label $bog_builderui_div sub / <= card_quality_label_text
				<= Metric_rows $bog_builderui_div sub <= metric_rows /
					<= Metric* $bog_norweb_front_dashboard_metric
						name <= metric_name* \
						value <= metric_value* \
						pct <= metric_pct* \0%
				<= Quality_footer $bog_builderui_div sub / <= quality_footer_text
			<= Card_energy $bog_builderui_div sub /
				<= Card_energy_label $bog_builderui_div sub / <= card_energy_label_text
				<= Energy_row $bog_builderui_div sub /
					<= Energy_kwh $bog_builderui_div sub /
						<= Energy_kwh_val $bog_builderui_div sub / <= energy_kwh_val \
						<= Energy_kwh_lbl $bog_builderui_div sub / <= energy_kwh_lbl_text
					<= Energy_cost $bog_builderui_div sub /
						<= Energy_cost_val $bog_builderui_div sub / <= energy_cost_val \
						<= Energy_cost_lbl $bog_builderui_div sub / <= energy_cost_lbl_text
				<= Energy_formula $bog_builderui_div sub / <= energy_formula_text
				<= Energy_note $bog_builderui_div sub / <= energy_note_text
			<= Card_timings $bog_builderui_div sub /
				<= Card_timings_label $bog_builderui_div sub / <= card_timings_label_text
				<= Stage_rows $bog_builderui_div sub <= stage_rows /
					<= Stage* $bog_norweb_front_dashboard_stage
						name <= stage_name* \
						time <= stage_time* \
						pct <= stage_pct* \0%
			<= Card_logs $bog_builderui_div sub /
				<= Card_logs_label $bog_builderui_div sub / <= card_logs_label_text
				<= Log_list $bog_builderui_div sub <= log_rows /
					<= Log* $bog_norweb_front_dashboard_log
						time <= log_time* \
						text <= log_text* \
						mode <= log_mode* \
						dur <= log_dur* \
						expanded? <=> log_expanded*? false
						chunks <= log_chunks* \
						communities <= log_communities* \
						retrieval <= log_retrieval* \
						generation <= log_generation* \
						power <= log_power* \
						trace_label <= trace_label_text
						trace_link <= trace_link_text
