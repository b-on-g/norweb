#!/bin/sh
# Heavy pre-push checks: full mam build + all tests.
# Активируется через ./.githooks/install.sh
set -e

REPO="$(git rev-parse --show-toplevel)"
MAM_ROOT="$(cd "$REPO/../.." && pwd)"

RED='\033[0;31m'; GRN='\033[0;32m'; NC='\033[0m'
fail() { printf "${RED}✗ %s${NC}\n" "$1" >&2; exit 1; }
ok()   { printf "${GRN}✓ %s${NC}\n" "$1"; }

if [ ! -d "$MAM_ROOT/node_modules/mam" ]; then
	fail "MAM не найден в $MAM_ROOT — pre-push требует чтобы репо лежал внутри mam"
fi

cd "$MAM_ROOT"

# 1. Full build
echo "▸ npx mam raggu/web/front/app"
if ! npx mam raggu/web/front/app > /tmp/raggu-push-build.log 2>&1; then
	tail -30 /tmp/raggu-push-build.log >&2
	fail "build failed"
fi
ok "build done"

# 2. Audit
AUDIT="$MAM_ROOT/raggu/web/front/app/-/web.audit.js"
if ! grep -q 'Audit passed' "$AUDIT"; then
	cat "$AUDIT" >&2
	fail "audit fail"
fi
ok "audit passed"

# 3. Tests
echo "▸ node front/app/-/node.test.js"
TEST_OUT=$(node --enable-source-maps "$MAM_ROOT/raggu/web/front/app/-/node.test.js" 2>&1)
if ! echo "$TEST_OUT" | grep -q 'All tests passed'; then
	echo "$TEST_OUT" | tail -30 >&2
	fail "tests failed"
fi
COUNT=$(echo "$TEST_OUT" | grep -oE 'count [0-9]+' | awk '{print $2}')
ok "tests passed ($COUNT)"

printf "${GRN}pre-push OK${NC}\n"
