$bog_ragufront_settings_group $bog_builderui_div
	step \
	title \
	opts \
	control \
	reindex true
	sub /
		<= Head $bog_builderui_div sub /
			<= Step $bog_builderui_div sub / <= step
			<= Reindex $bog_builderui_div
				attr * bog_ragufront_settings_group_reindex <= reindex
				sub / \требует переиндексации
		<= Title $bog_builderui_div sub / <= title
		<= Opts $bog_builderui_div sub / <= opts
		<= Control $bog_builderui_div sub / <= control
